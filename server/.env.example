# 서버 포트
PORT=4000

# JWT 로그인 토큰 서명 비밀키 (실제 값은 server/.env 에 두고 깃에 올리지 말 것)
# 생성 예: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=여기에_긴_랜덤_문자열
JWT_EXPIRES_IN=2h

# (선택) 서비스 계정 키 경로를 직접 지정하고 싶을 때만 사용
# 기본값은 server/meowcretary-firebase-adminsdk-fbsvc-6d634af0a5.json
# FIREBASE_SERVICE_ACCOUNT=./meowcretary-firebase-adminsdk-fbsvc-6d634af0a5.json

# (참고) 프로필 사진은 무료 요금제에서 동작하도록 Firestore에 base64로 저장한다.
# Firebase Storage는 사용하지 않으므로 별도 버킷 설정이 필요 없다.
