# 카카오 지도 API 키
# https://developers.kakao.com 에서 앱 등록 후 JavaScript 키를 입력하세요
# 플랫폼 설정에서 "웹" → 사이트 도메인에 http://localhost:5173 추가 필요
VITE_KAKAO_MAP_KEY=your_key_here

# 백엔드 서버 주소 (기본값: http://localhost:4000)
# VITE_API_BASE=http://localhost:4000

# Firebase 웹 설정 (구글 로그인/Firestore) — 콘솔 > 프로젝트 설정 > 내 앱 에서 복사
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=meowcretary.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=meowcretary
VITE_FIREBASE_STORAGE_BUCKET=meowcretary.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
